{
  "name": "georgejkaye.github.io",
  "version": "2.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/georgejkaye/georgejkaye.github.io"
  },
  "type": "module",
  "scripts": {
    "watch:eleventy": "npx @11ty/eleventy --serve",
    "watch:sass": "npx sass sass:build/css --watch",
    "watch:tailwindcss": "npx @tailwindcss/cli -i tailwind/tailwind.css -o build/css/tailwind.css --watch",
    "start": "concurrently \"npm run watch:eleventy\" \"npm run watch:sass\" \"npm run watch:tailwindcss\"",
    "build:eleventy": "npx @11ty/eleventy",
    "build:sass": "npx sass sass:build/css",
    "build:tailwindcss": "npx @tailwindcss/cli -i tailwind/tailwind.css -o build/css/tailwind.css",
    "format": "npx prettier --ignore-path .prettierignore --write build"
  },
  "dependencies": {
    "@11ty/eleventy": "^3",
    "@vscode/markdown-it-katex": "^1.1.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.21",
    "lodash.chunk": "^4.2.0",
    "markdown-it": "^14.1.1",
    "markdown-it-attrs": "^4.1.4",
    "moment": "^2.29.4",
    "outdent": "^0.8.0",
    "postcss": "^8.5.12",
    "prettier": "^3.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sass": "^1.43.4",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@11ty/eleventy-plugin-syntaxhighlight": "^4.1.4",
    "@tailwindcss/cli": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  },
  "license": "GPL-3.0-or-later"
}
